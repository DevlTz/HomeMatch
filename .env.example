# Django
DEBUG=True
SECRET_KEY=change-before-deploying

# Database (PostgreSQL)
DB_NAME=homematch_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db          # use "localhost" when running outside Docker
DB_PORT=5432

# Cloudflare R2 (image storage)
# Leave blank in local dev if you don't need photo upload.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=

# AI Vision API
# Required only for the /api/ai-analysis/ endpoints.
# Point AI_API_BASE_URL at a local LM Studio instance for offline development.
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-4o-mini
